<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>com.ibm.icu</groupId>
    <artifactId>icu4j-tools</artifactId>
    <version>79.0.1-SNAPSHOT</version>
  </parent>

  <artifactId>tools_build</artifactId>

  <properties>
    <api_report_version>${icu.major.version}</api_report_version>
    <api_report_prev_version>78</api_report_prev_version>
    <out_dir>target</out_dir>
  </properties>

  <profiles>
  <profile>
    <id>api_reports</id>
    <build>
      <plugins>
        <plugin>
          <groupId>org.codehaus.mojo</groupId>
          <artifactId>exec-maven-plugin</artifactId>
          <executions>
            <execution>
              <id>run-ReportAPI</id>
              <phase>package</phase>
              <goals>
                <goal>java</goal>
              </goals>
              <configuration>
                <mainClass>com.ibm.icu.dev.tool.docs.ReportAPI</mainClass>
                <arguments>
                  <argument>-old:</argument>
                  <argument>tools/build/icu4j${api_report_prev_version}.api3.gz</argument>
                  <argument>-new:</argument>
                  <argument>${out_dir}/icu4j${api_report_version}.api3.gz</argument>
                  <argument>-html</argument>
                  <argument>-out:</argument>
                  <argument>${out_dir}/icu4j_compare_${api_report_prev_version}_${api_report_version}.html</argument>
                </arguments>
              </configuration>
            </execution>
            <execution>
              <id>run-DeprecatedAPIChecker</id>
              <phase>verify</phase>
              <goals>
                <goal>java</goal>
              </goals>
              <configuration>
                <mainClass>com.ibm.icu.dev.tool.docs.DeprecatedAPIChecker</mainClass>
                <arguments>
                  <argument>${out_dir}/icu4j${api_report_version}.api3.gz</argument>
                </arguments>
                <additionalClasspathElements>
                  <additionalClasspathElement>${maven.multiModuleProjectDirectory}\icu4j\main\icu4j\target\icu4j-${project.version}.jar</additionalClasspathElement>
                  <additionalClasspathElement>${maven.multiModuleProjectDirectory}\icu4j\main\charset\target\icu4j-charset-${project.version}.jar</additionalClasspathElement>
                </additionalClasspathElements>
              </configuration>
            </execution>
            <execution>
              <id>run-APIStatusConsistencyChecker</id>
              <phase>verify</phase>
              <goals>
                <goal>java</goal>
              </goals>
              <configuration>
                <mainClass>com.ibm.icu.dev.tool.docs.APIStatusConsistencyChecker</mainClass>
                <arguments>
                  <argument>${out_dir}/icu4j${api_report_version}.api3.gz</argument>
                  <argument>checkAPIStatusConsistency.skip.classes=</argument>
                </arguments>
              </configuration>
            </execution>
            <execution>
              <id>run-CollectAPI-html</id>
              <phase>verify</phase>
              <goals>
                <goal>java</goal>
              </goals>
              <configuration>
                <mainClass>com.ibm.icu.dev.tool.docs.CollectAPI</mainClass>
                <arguments>
                  <argument>-f</argument>
                  <argument>Draft</argument>
                  <argument>-o</argument>
                  <argument>${out_dir}/draftAPIs.html</argument>
                  <argument>${out_dir}/icu4j${api_report_version}.api3.gz</argument>
                </arguments>
              </configuration>
            </execution>
            <execution>
              <id>run-CollectAPI-tsv</id>
              <phase>verify</phase>
              <goals>
                <goal>java</goal>
              </goals>
              <configuration>
                <mainClass>com.ibm.icu.dev.tool.docs.CollectAPI</mainClass>
                <arguments>
                  <argument>-f</argument>
                  <argument>Draft</argument>
                  <argument>-t</argument>
                  <argument>-o</argument>
                  <argument>${out_dir}/draftAPIs.tsv</argument>
                  <argument>${out_dir}/icu4j${api_report_version}.api3.gz</argument>
                </arguments>
              </configuration>
            </execution>
          </executions>
        </plugin>

      </plugins>
    </build>
  </profile>
  </profiles>

</project>
